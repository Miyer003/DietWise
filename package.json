{
  "name": "dietwise",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:clear": "expo start --dev-client -c",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "android": "expo start --android --dev-client",
    "android:clean": "adb reverse --remove-all && npx expo start --localhost",
    "build:dev": "eas build --profile development --platform android",
    
    "prebuild": "npx expo prebuild --platform android",
    "prebuild:clean": "npx expo prebuild --clean --platform android",
    "build:local": "cd android && ./gradlew assembleDebug && cd ..",
    "build:local:install": "cd android && ./gradlew installDebug && cd ..",
    "android:studio": "open -a \"Android Studio\" android/"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.4",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "expo": "~52.0.0",
    "expo-av": "~15.0.2",
    "expo-camera": "~16.0.18",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.0.11",
    "expo-image-manipulator": "~13.0.6",
    "expo-image-picker": "~16.0.6",
    "expo-notifications": "~0.29.14",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@types/axios": "^0.14.0",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.72.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "typescript": "~5.9.2"
  },
  "private": true
}
